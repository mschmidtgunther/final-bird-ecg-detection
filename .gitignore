# Ignorar base de datos local, descargas y archivos procesados gigantes
# Ignorar el contenido de la carpeta de datos
data/*
data/raw/*
*.zip
*.tar
*.tar.gz
*.h5
*.hdf5

# Ignorar archivos de imágenes generadas
*.jpg
*.jpeg
*.png

# Ignorar entornos virtuales y sistema
.venv/
.DS_Store

# Ignorar archivos temporales de Python y Jupyter
__pycache__/
*.pyc
.ipynb_checkpoints/

# Excepciones: mantener la estructura de carpetas de datos (solo los .gitkeep)
# Excepciones: mantener solo los archivos ocultos de estructura
!data/.gitkeep
!data/raw/.gitkeep
!data/
!data/raw/
!data/raw/.gitkeep